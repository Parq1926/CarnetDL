<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " - Carnet Digital" : "Carnet Digital CUC")</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.3/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.11.3/font/bootstrap-icons.min.css" />
    <style>
        :root { --azul: #1b2a4a; --azul-claro: #24365f; }
        body { background: #f4f6f9; }
        .sidebar { width: 230px; min-height: 100vh; background: var(--azul); position: fixed; left: 0; top: 0; }
        .sidebar .brand { color: #fff; padding: 18px 16px; font-weight: 600; border-bottom: 1px solid rgba(255,255,255,.1); }
        .sidebar a { display: block; color: #c7d0e0; padding: 12px 18px; text-decoration: none; font-size: .95rem; }
        .sidebar a.active, .sidebar a:hover { background: var(--azul-claro); color: #fff; }
        .content { margin-left: 230px; }
        .topbar { background: #fff; border-bottom: 1px solid #e3e6ec; padding: 10px 20px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 8px; }
        .main { padding: 24px; }
        .card-panel { background: #fff; border: 1px solid #e3e6ec; border-radius: 8px; padding: 20px; }
        .foto-preview { width: 180px; height: 180px; object-fit: cover; border: 1px solid #dde; border-radius: 6px; background: #eee; }
        .qr-preview { width: 220px; height: 220px; object-fit: contain; border: 1px solid #dde; border-radius: 6px; background: #fff; }
    </style>
</head>
<body>
    <div class="sidebar">
        <div class="brand"><i class="bi bi-person-badge"></i> Carnet Digital</div>
        <nav>
            <a href="/EstadoUsuario"><i class="bi bi-toggle2-on"></i> Cambio de Estado</a>
            <a href="/Qr"><i class="bi bi-qr-code"></i> Código QR</a>
            <a href="/Fotografia"><i class="bi bi-image"></i> Fotografía</a>
            <a href="/Parametro"><i class="bi bi-sliders"></i> Parámetros</a>
        </nav>
    </div>

    <div class="content">
        <div class="topbar">
            <h5 class="mb-0">@ViewData["Title"]</h5>
            <form method="post" action="/set-token" class="d-flex align-items-center gap-2">
                @if (!string.IsNullOrEmpty(Context.Session.GetString("Token")))
                {
                    <span class="badge bg-success">Token cargado</span>
                }
                else
                {
                    <span class="badge bg-secondary">Sin token</span>
                }
                <input type="password" name="token" class="form-control form-control-sm" style="width:320px" placeholder="Pega aquí el JWT (Bearer)" />
                <button class="btn btn-sm btn-primary" type="submit">Guardar</button>
            </form>
        </div>

        <div class="main">
            @if (TempData["Mensaje"] is string mensaje)
            {
                var tipo = TempData["MensajeTipo"] as string ?? "info";
                <div class="alert alert-@tipo alert-dismissible fade show" role="alert">
                    @mensaje
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.3/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
