<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Carnet Digital CUC</title>
    <link rel="stylesheet" href="~/css/site.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <div class="app-container">
        <!-- ======================================== -->
        <!-- SIDEBAR - MENÚ LATERAL                   -->
        <!-- ======================================== -->
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <div class="logo-sidebar">
                    <div class="logo-icon">CUC</div>
                    <span class="logo-text">Carnet Digital</span>
                </div>
            </div>
            <nav class="sidebar-nav">
                <ul>
                    <li id="menu-welcome">
                        <a href="javascript:void(0)" onclick="abrirInicio();">
                            <i class="fas fa-home"></i>
                            <span>Inicio</span>
                        </a>
                    </li>
                    <li id="menu-usuarios">
                        <a href="javascript:void(0)" onclick="abrirUsuarios();">
                            <i class="fas fa-users"></i>
                            <span>Usuarios</span>
                        </a>
                    </li>
                    <li id="menu-tipos-usuario">
                        <a href="javascript:void(0)" onclick="abrirTiposUsuario();">
                            <i class="fas fa-user-tag"></i>
                            <span>Tipos de Usuario</span>
                        </a>
                    </li>
                    <li class="active" id="menu-tipos-identificacion">
                        <a href="javascript:void(0)" onclick="abrirTiposIdentificacion();">
                            <i class="fas fa-id-card"></i>
                            <span>Tipos de Identificación</span>
                        </a>
                    </li>
                    <li id="menu-carreras">
                        <a href="javascript:void(0)" onclick="abrirCarreras();">
                            <i class="fas fa-graduation-cap"></i>
                            <span>Carreras</span>
                        </a>
                    </li>
                    <li id="menu-areas">
                        <a href="javascript:void(0)" onclick="abrirAreas();">
                            <i class="fas fa-building"></i>
                            <span>Áreas</span>
                        </a>
                    </li>
                    <li id="menu-instituciones">
                        <a href="javascript:void(0)" onclick="abrirInstituciones();">
                            <i class="fas fa-university"></i>
                            <span>Instituciones</span>
                        </a>
                    </li>
                    <li class="divider"></li>
                    <li>
                        <a href="javascript:void(0)" onclick="cerrarSesion();" class="logout-link">
                            <i class="fas fa-sign-out-alt"></i>
                            <span>Cerrar Sesión</span>
                        </a>
                    </li>
                </ul>
            </nav>
        </aside>

        <!-- ======================================== -->
        <!-- CONTENIDO PRINCIPAL                      -->
        <!-- ======================================== -->
        <main class="main-content">
            <header class="top-bar">
                <div class="top-bar-left">
                    <button class="menu-toggle" onclick="toggleSidebar()">
                        <i class="fas fa-bars"></i>
                    </button>
                    <span class="page-title">@ViewData["Title"]</span>
                </div>
                <div class="top-bar-right">
                    <div class="user-info">
                        <div class="user-avatar">
                            <i class="fas fa-user-circle"></i>
                        </div>
                        <span class="user-name" id="userName">Usuario</span>
                        <span class="user-role" id="userRole"></span>
                    </div>
                </div>
            </header>

            <div class="page-content">
                @RenderBody()
            </div>
        </main>
    </div>

    <script>
            // ========================================
            // 🔐 VERIFICACIÓN DE AUTENTICACIÓN
            // ========================================
            document.addEventListener('DOMContentLoaded', function() {
                var token = localStorage.getItem('accessToken');
                var currentPath = window.location.pathname;
                var isLoginPage = currentPath.includes('/Login');

                if (!token && !isLoginPage) {
                    localStorage.setItem('redirectMessage', 'Por favor inicie sesión para utilizar el sistema');
                    window.location.href = 'https://localhost:7019/Login';
                    return;
                }

                if (token) {
                    var nombre = localStorage.getItem('nombreCompleto') || 'Usuario';
                    var tipo = localStorage.getItem('usuarioTipo') || '';
                    document.getElementById('userName').textContent = nombre;
                    document.getElementById('userRole').textContent = tipo ? '(' + tipo + ')' : '';
                }

                // Marcar menú activo
                var menuItems = document.querySelectorAll('.sidebar-nav ul li');
                menuItems.forEach(function(item) {
                    var link = item.querySelector('a');
                    if (link) {
                        var onclick = link.getAttribute('onclick');
                        if (onclick && onclick.includes('abrirTiposIdentificacion')) {
                            item.classList.add('active');
                        } else {
                            item.classList.remove('active');
                        }
                    }
                });
            });

            // ========================================
            // FUNCIONES GENERALES
            // ========================================

            function toggleSidebar() {
                document.getElementById('sidebar').classList.toggle('open');
            }

            function cerrarSesion() {
                localStorage.clear();
                window.location.href = 'https://localhost:7019/Login';
            }

            // ========================================
            // 🔗 FUNCIONES PARA ABRIR MICROSERVICIOS
            // ========================================

            function abrirInicio() {
                window.location.href = 'https://localhost:7019/Welcome';
            }

            function abrirUsuarios() {
                window.location.href = 'https://localhost:7206/Usuarios';
            }

            function abrirTiposUsuario() {
                window.location.href = 'https://localhost:7020/TiposUsuario';
            }

            function abrirTiposIdentificacion() {
                window.location.href = 'https://localhost:7021/TiposIdentificacion';
            }

            function abrirCarreras() {
                window.location.href = 'http://localhost:5280/Carreras';
            }

            function abrirAreas() {
                window.location.href = 'http://localhost:5202/Areas';
            }

            function abrirInstituciones() {
                window.location.href = 'http://localhost:7002/Instituciones';
            }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>